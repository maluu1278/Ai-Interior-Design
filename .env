# Default: real image generation using Pollinations.
# This works without an API key for testing/free use.
AI_PROVIDER=pollinations
POLLINATIONS_MODEL=flux
IMAGE_WIDTH=1024
IMAGE_HEIGHT=1024
PORT=3000

# Optional: if you create a Pollinations key, paste it here.
# POLLINATIONS_API_KEY=sk-your-pollinations-key

# Optional OpenAI setup. Change AI_PROVIDER=openai to use it.
# OPENAI_API_KEY=sk-your-openai-key
# IMAGE_MODEL=gpt-image-1
# OPENAI_IMAGE_SIZE=1024x1024

# Optional Hugging Face setup. Change AI_PROVIDER=huggingface to use it.
# HF_TOKEN=hf-your-token
# HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell

# Keep false if you want to prove the app is not using demo images.
USE_DEMO_FALLBACK=false
